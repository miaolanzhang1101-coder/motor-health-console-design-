'use client';
import { useState } from 'react';
import { motion, AnimatePresence, useReducedMotion } from 'framer-motion';
import DraggableSignalTrace from './DraggableSignalTrace';
import MotorDiagram from './MotorDiagram';
import Button from './ui/Button';
import Tabs from './ui/Tabs';
import StatCard from './ui/StatCard';
import DataTable from './ui/DataTable';
import Checkbox from './ui/Checkbox';
import Input from './ui/Input';
import { statusToSeverity, SeverityLevel, SEVERITY_COLORS, SEVERITY_LABELS } from '../lib/severity';
import { toDeviationIndex } from '../lib/normalize';
import { Motor, ActionState } from '../lib/types';
import { ThresholdValues, getMotorTypeLabel } from '../lib/thresholdTree';

interface MotorInspectorProps {
  motor: Motor | null;
  action: ActionState;
  onActionChange: (action: ActionState) => void;
  thresholds: ThresholdValues;
  hasOwnOverride?: boolean;
  onThresholdOverrideChange?: (override: ThresholdValues | null) => void;
}

const ACTION_COPY: Record<Exclude<ActionState, 'none'>, string> = {
  acknowledged: 'MARKED AS REVIEWED — no further action logged.',
  scheduled: 'INSPECTION SCHEDULED — surfaces on the maintenance queue.',
  escalated: 'ESCALATED — on-call maintenance lead notified.',
};

interface RehearseInfo {
  isRehearsing: boolean;
  severity: SeverityLevel;
}

export default function MotorInspector({
  motor,
  action,
  onActionChange,
  thresholds,
  hasOwnOverride = false,
  onThresholdOverrideChange,
}: MotorInspectorProps) {
  const reduceMotion = useReducedMotion();
  const [rmsRehearse, setRmsRehearse] = useState<RehearseInfo | null>(null);
  const [kurtRehearse, setKurtRehearse] = useState<RehearseInfo | null>(null);
  const [zoomRange, setZoomRange] = useState<[number, number] | null>(null);
  const [tab, setTab] = useState<'traces' | 'windows'>('traces');

  if (!motor) {
    return (
      <div className="p-8 text-[#4A4E5C] text-xs font-mono">
        SELECT A MOTOR FROM FLEET CONSOLE TO INSPECT
      </div>
    );
  }

  const overall = statusToSeverity(motor.status);
  const overallColor = SEVERITY_COLORS[overall];
  const rmsHistory = toDeviationIndex(motor.windows.map((w) => Number(w.rms) || 0));
  const kurtosisHistory = toDeviationIndex(motor.windows.map((w) => Number(w.kurtosis) || 0));
  const faultFlags = motor.windows.map((w) => w.label === 'fault');
  const topContributor = motor.avgKurt >= motor.avgRms * 3 ? 'kurtosis' : 'rms';

  const rehearsingCritical =
    (rmsRehearse?.isRehearsing && rmsRehearse.severity === 'critical') ||
    (kurtRehearse?.isRehearsing && kurtRehearse.severity === 'critical');

  return (
    <motion.div
      key={motor.file}
      initial={reduceMotion ? false : { opacity: 0, y: 6 }}
      animate={{ opacity: 1, y: 0 }}
      transition={reduceMotion ? { duration: 0 } : { duration: 0.2, ease: 'easeOut' }}
      className="p-5 flex flex-col gap-4"
    >
      {/* Header */}
      <div className="flex items-center justify-between">
        <h1 className="text-base font-mono font-semibold text-[#D7D9E0]">{motor.name}</h1>
        <span className="text-[10px] font-mono text-[#4A4E5C]">
          THRESHOLDS {thresholds.watch}/{thresholds.critical}
        </span>
      </div>

      {/* KPI row */}
      <div className="grid grid-cols-4 gap-3">
        <StatCard label="Risk Level" value={SEVERITY_LABELS[overall]} color={overallColor} big />
        <StatCard label="Total Windows" value={motor.total} />
        <StatCard label="Fault Rate" value={`${motor.faultPct.toFixed(1)}%`} />
        <StatCard label="Avg Kurtosis" value={motor.avgKurt.toFixed(2)} />
      </div>

      {/* Main split: diagram left, tabbed detail right */}
      <div className="grid grid-cols-[280px_1fr] gap-4">
        <div className="flex flex-col gap-3">
          <MotorDiagram
            motorType={getMotorTypeLabel(motor.file)}
            severity={overall}
            topContributor={topContributor}
          />

          {onThresholdOverrideChange && (
            <div className="border border-[#1E212A] bg-[#111318] p-3">
              <div className="text-[9px] font-mono uppercase tracking-wide text-[#4A4E5C] mb-2">
                Quick Adjust
              </div>
              <Checkbox
                checked={hasOwnOverride}
                onChange={(checked) => onThresholdOverrideChange(checked ? { ...thresholds } : null)}
                label="OVERRIDE FOR THIS MOTOR"
              />
              {hasOwnOverride && (
                <div className="grid grid-cols-2 gap-2 mt-2">
                  <div>
                    <label className="block text-[9px] font-mono uppercase text-[#4A4E5C] mb-1">Watch</label>
                    <Input
                      type="number"
                      value={thresholds.watch}
                      color="#F59E0B"
                      onChange={(v) => onThresholdOverrideChange({ ...thresholds, watch: Number(v) })}
                    />
                  </div>
                  <div>
                    <label className="block text-[9px] font-mono uppercase text-[#4A4E5C] mb-1">Critical</label>
                    <Input
                      type="number"
                      value={thresholds.critical}
                      color="#EF4444"
                      onChange={(v) => onThresholdOverrideChange({ ...thresholds, critical: Number(v) })}
                    />
                  </div>
                </div>
              )}
            </div>
          )}
        </div>

        <div className="border border-[#1E212A] bg-[#111318] p-4">
          <Tabs
            tabs={[
              { key: 'traces', label: 'Signal Traces' },
              { key: 'windows', label: 'Window Data' },
            ]}
            active={tab}
            onChange={(k) => setTab(k as 'traces' | 'windows')}
          />

          {tab === 'traces' && (
            <div className="mt-4 flex flex-col gap-3">
              <DraggableSignalTrace
                label="RMS amplitude"
                unit="idx"
                history={rmsHistory}
                faultFlags={faultFlags}
                thresholds={thresholds}
                isTopContributor={topContributor === 'rms'}
                accentColor="#22D3EE"
                onRehearseChange={setRmsRehearse}
                zoomRange={zoomRange}
                onZoomChange={setZoomRange}
              />
              <DraggableSignalTrace
                label="Kurtosis"
                unit="idx"
                history={kurtosisHistory}
                faultFlags={faultFlags}
                thresholds={thresholds}
                isTopContributor={topContributor === 'kurtosis'}
                accentColor="#A78BFA"
                onRehearseChange={setKurtRehearse}
                zoomRange={zoomRange}
                onZoomChange={setZoomRange}
              />

              <AnimatePresence>
                {rehearsingCritical && action === 'none' && (
                  <motion.div
                    initial={reduceMotion ? false : { opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={reduceMotion ? undefined : { opacity: 0, height: 0 }}
                    transition={reduceMotion ? { duration: 0 } : { duration: 0.2 }}
                    className="overflow-hidden"
                  >
                    <div className="flex items-center justify-between gap-3 border border-[#EF4444]/40 bg-[#EF4444]/10 px-3 py-2">
                      <span className="text-[10px] font-mono text-[#EF4444]">
                        REHEARSAL SHOWS CRITICAL — schedule an inspection before this drift becomes real?
                      </span>
                      <Button variant="danger" size="sm" onClick={() => onActionChange('scheduled')}>
                        Schedule now
                      </Button>
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>

              <div className="flex gap-2 pt-1">
                <Button variant="primary" active={action === 'acknowledged'} onClick={() => onActionChange('acknowledged')}>
                  Acknowledge
                </Button>
                <Button variant="primary" active={action === 'scheduled'} onClick={() => onActionChange('scheduled')}>
                  Schedule
                </Button>
                <Button variant="danger" active={action === 'escalated'} onClick={() => onActionChange('escalated')}>
                  Escalate
                </Button>
              </div>

              <AnimatePresence mode="wait">
                {action !== 'none' && (
                  <motion.p
                    key={action}
                    initial={reduceMotion ? false : { opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={reduceMotion ? undefined : { opacity: 0, height: 0 }}
                    transition={reduceMotion ? { duration: 0 } : { duration: 0.15 }}
                    className="text-[10px] font-mono text-[#4A4E5C] overflow-hidden"
                  >
                    {ACTION_COPY[action]}
                  </motion.p>
                )}
              </AnimatePresence>
            </div>
          )}

          {tab === 'windows' && (
            <div className="mt-4">
              <DataTable
                maxHeight={420}
                columns={[
                  { key: 'i', label: 'Window', render: (_r, i) => i },
                  { key: 'rms', label: 'RMS', render: (r: (typeof motor.windows)[number]) => Number(r.rms).toFixed(3), align: 'right' },
                  { key: 'kurt', label: 'Kurtosis', render: (r: (typeof motor.windows)[number]) => Number(r.kurtosis).toFixed(3), align: 'right' },
                  { key: 'crest', label: 'Crest', render: (r: (typeof motor.windows)[number]) => Number(r.crest_factor).toFixed(3), align: 'right' },
                  { key: 'peak', label: 'Peak', render: (r: (typeof motor.windows)[number]) => Number(r.peak).toFixed(3), align: 'right' },
                  {
                    key: 'label',
                    label: 'Label',
                    render: (r: (typeof motor.windows)[number]) => (
                      <span style={{ color: r.label === 'fault' ? '#EF4444' : '#4A4E5C' }}>{r.label}</span>
                    ),
                  },
                ]}
                rows={motor.windows}
              />
            </div>
          )}
        </div>
      </div>
    </motion.div>
  );
}